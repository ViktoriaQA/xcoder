# Server Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Production URLs
VITE_API_BASE_URL=https://your-backend-production-url.com
PRODUCTION_FRONTEND_URL=https://olimpxx.pp.ua

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Monobank Configuration
MONOBANK_TOKEN=dfsdfsdferedadbg
MONOBANK_WEBHOOK_SECRET=your_monobank_webhook_secret_here
# Development URLs (for local testing)
MONOBANK_CALLBACK_URL=http://localhost:8080/api/v1/payment/callback
MONOBANK_RESULT_URL=http://localhost:5173/subscription/success
# Production URLs (uncomment for production)
# MONOBANK_CALLBACK_URL=https://olimpxx.pp.ua/api/v1/payment/callback
# MONOBANK_RESULT_URL=https://olimpxx.pp.ua/subscription/success

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Database Configuration (if using direct database connection)
DATABASE_URL=your_database_url_here

# Email Configuration (optional)
SMTP_HOST=your_smtp_host_here
SMTP_PORT=587
SMTP_USER=your_smtp_user_here
SMTP_PASS=your_smtp_pass_here
FROM_EMAIL=noreply@olimpxx.pp.ua

# Redis Configuration (optional for caching)
REDIS_URL=redis://localhost:6379

# File Upload Configuration
MAX_FILE_SIZE=10mb
UPLOAD_PATH=./uploads

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Security Configuration
CORS_ORIGIN=http://localhost:5173,https://olimpx-production.up.railway.app,https://olimpxx.pp.ua
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=false
ENABLE_SOCIAL_LOGIN=false

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Discord OAuth Configuration
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:3001/auth/discord/callback

# Monitoring Configuration
SENTRY_DSN=your_sentry_dsn_here

# Analytics Configuration
GOOGLE_ANALYTICS_ID=your_ga_id_here

# Payment Configuration
CURRENCY=UAH
DEFAULT_SUBSCRIPTION_PRICE=99
YEARLY_DISCOUNT=0.17

# Piston API Configuration
PISTON_API_URL=http://localhost:2000

# Code Execution Services Configuration
# JDoodle API Configuration
JDOODLE_CLIENT_ID=your_jdoodle_client_id_here
JDOODLE_CLIENT_SECRET=your_jdoodle_client_secret_here

# OneCompiler API Configuration
ONECOMPILER_API_KEY=your_onecompiler_api_key_here

# Glot API Configuration
GLOT_API_TOKEN=your_glot_api_token_here

# MyCompiler API Configuration
MYCOMPILER_API_KEY=your_mycompiler_api_key_here

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_TOPIC_PAY=your_telegram_pay_topic_id_here
TELEGRAM_TOPIC_NEW_USER=your_telegram_new_user_topic_id_here
TELEGRAM_TOPIC_ERRORS=your_telegram_errors_topic_id_here
