# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database Configuration (if using direct database connection)
DATABASE_URL=your_database_url

# Payment Configuration (LiqPay)
LIQPAY_PUBLIC_KEY=your_liqpay_public_key
LIQPAY_PRIVATE_KEY=your_liqpay_private_key

# JWT Configuration (if needed for additional tokens)
JWT_SECRET=your_jwt_secret_key

# Logging
LOG_LEVEL=info