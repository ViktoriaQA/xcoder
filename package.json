{
  "scripts": {
    "start": "chmod +x start.sh && ./start.sh",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run install:frontend && npm run install:backend && npm run build:frontend && npm run build:backend",
    "install:frontend": "cd frontend && npm ci",
    "install:backend": "cd backend && npm ci",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "playwright install",
    "test:e2e:prod": "BASE_URL=https://olimpxx.pp.ua playwright test",
    "test:e2e:staging": "BASE_URL=https://staging.olimpxx.pp.ua playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "concurrently": "^8.2.2",
    "supabase": "^2.76.12"
  },
  "dependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "jsonwebtoken": "^9.0.3"
  }
}
